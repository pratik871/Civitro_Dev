{
  "expo": {
    "name": "Civitro",
    "slug": "civitro",
    "owner": "pratikbloom",
    "version": "1.2.0",
    "orientation": "portrait",
    "scheme": "civitro",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A365D"
    },
    "android": {
      "package": "in.civitro.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "civitro.com",
              "pathPrefix": "/share"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "softwareKeyboardLayoutMode": "adjustResize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "in.civitro.app",
      "buildNumber": "25",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:civitro.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Civitro needs camera access to capture issue photos",
        "NSPhotoLibraryUsageDescription": "Civitro needs photo library access to attach images to issues",
        "NSLocationWhenInUseUsageDescription": "Civitro needs your location to show nearby civic issues",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-location",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "6af66eba-ce0c-4b8f-ad6c-0ead2a2c5be2"
      }
    }
  }
}
